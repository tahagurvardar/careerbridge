# Application runtime: use the pooled Neon connection.
DATABASE_URL="postgresql://USER:PASSWORD@POOLED_HOST/DATABASE?sslmode=verify-full"

# Prisma CLI and migrations: use the direct Neon connection.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=verify-full"

# Better Auth requires a high-entropy secret of at least 32 characters.
BETTER_AUTH_SECRET="replace-with-a-high-entropy-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Database integration tests are excluded from npm test. Use a dedicated test database only.
# The integration command refuses a TEST_DATABASE_URL matching an application database URL.
RUN_DATABASE_INTEGRATION_TESTS="false"
TEST_DATABASE_URL="postgresql://USER:PASSWORD@DEDICATED_TEST_HOST/TEST_DATABASE?sslmode=verify-full"

# Optional development-only admin bootstrap. Keep disabled unless intentionally running it.
# This dedicated URL, not DATABASE_URL, is the only database target the command uses.
ADMIN_BOOTSTRAP_ENABLED="false"
ADMIN_BOOTSTRAP_DATABASE_URL="postgresql://USER:PASSWORD@DEVELOPMENT_DIRECT_HOST/DATABASE?sslmode=verify-full"
ADMIN_BOOTSTRAP_NAME="Development Admin"
ADMIN_BOOTSTRAP_EMAIL="admin@example.test"
ADMIN_BOOTSTRAP_PASSWORD="replace-with-a-unique-development-password"
