# Application
# Canonical public HTTPS origin in production; local development may use localhost.
APP_BASE_URL=

# Database
# Pooled runtime connection and distinct direct Prisma migration connection.
DATABASE_URL=
DIRECT_URL=

# Authentication
# Better Auth origin must equal APP_BASE_URL in production. Extra origins are
# comma-separated exact HTTPS origins; wildcards are rejected.
BETTER_AUTH_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_TRUSTED_ORIGINS=
# Optional development-only Admin bootstrap. Never enable in production.
ADMIN_BOOTSTRAP_ENABLED=
ADMIN_BOOTSTRAP_DATABASE_URL=
ADMIN_BOOTSTRAP_NAME=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# Storage
# Use local only in development/test. Vercel Preview and Production require a
# private S3-compatible bucket with no public object URLs.
DOCUMENT_STORAGE_DRIVER=
DOCUMENT_STORAGE_LOCAL_ROOT=
DOCUMENT_STORAGE_S3_ENDPOINT=
DOCUMENT_STORAGE_S3_REGION=
DOCUMENT_STORAGE_S3_BUCKET=
DOCUMENT_STORAGE_S3_ACCESS_KEY_ID=
DOCUMENT_STORAGE_S3_SECRET_ACCESS_KEY=
DOCUMENT_STORAGE_S3_FORCE_PATH_STYLE=

# Email
# Development/test may use log. Production requires resend and a verified sender.
EMAIL_DELIVERY_DRIVER=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=
EMAIL_REPLY_TO=
EMAIL_RESEND_API_KEY=
EMAIL_APP_BASE_URL=
EMAIL_BATCH_SIZE=
EMAIL_MAX_ATTEMPTS=

# Dispatcher / Cron
# Keep the existing POST dispatcher and Vercel Cron secrets separate.
EMAIL_DISPATCH_SECRET=
CRON_SECRET=

# Deployment
# VERCEL_ENV and VERCEL_URL are supplied by Vercel. The remaining values belong
# only in the protected GitHub production Environment, not local/Vercel runtime.
VERCEL_ENV=
VERCEL_URL=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
PRODUCTION_DIRECT_URL=
SMOKE_TEST_BASE_URL=

# Testing
# Integration tests require explicit opt-in and a dedicated non-application DB.
RUN_DATABASE_INTEGRATION_TESTS=
TEST_DATABASE_URL=
