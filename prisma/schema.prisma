// CareerBridge identity, Candidate profile, and Recruiter Company workspace.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  TEMPORARY
  FREELANCE
}

enum CompanySize {
  SOLO
  TWO_TO_TEN
  ELEVEN_TO_FIFTY
  FIFTY_ONE_TO_TWO_HUNDRED
  TWO_HUNDRED_ONE_TO_FIVE_HUNDRED
  FIVE_HUNDRED_ONE_TO_ONE_THOUSAND
  ONE_THOUSAND_PLUS
}

enum CompanyMembershipRole {
  OWNER
  MEMBER
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum WorkplaceType {
  ONSITE
  HYBRID
  REMOTE
}

enum ExperienceLevel {
  ENTRY
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum CandidateDocumentKind {
  RESUME
}

enum CandidateDocumentAccessType {
  OWNER_DOWNLOAD
  RECRUITER_APPLICATION_DOWNLOAD
}

enum ApplicationNoteRevisionAction {
  CREATED
  EDITED
  DELETED
}

enum NotificationType {
  APPLICATION_SUBMITTED
  APPLICATION_STATUS_CHANGED
  APPLICATION_WITHDRAWN
  COMPANY_INVITATION_RECEIVED
  INTERVIEW_SCHEDULED
  INTERVIEW_RESCHEDULED
  INTERVIEW_CANCELED
  INTERVIEW_RESPONSE_RECEIVED
}

enum EmailEventType {
  COMPANY_INVITATION_RECEIVED
  APPLICATION_SUBMITTED
  APPLICATION_STATUS_CHANGED
  APPLICATION_WITHDRAWN
  INTERVIEW_SCHEDULED
  INTERVIEW_RESCHEDULED
  INTERVIEW_CANCELED
  INTERVIEW_RESPONSE_RECEIVED
}

enum InterviewFormat {
  VIDEO
  PHONE
  ONSITE
  OTHER
}

enum InterviewStatus {
  PENDING_RESPONSE
  ACCEPTED
  DECLINED
  CANCELED
  COMPLETED
}

enum InterviewEventType {
  CREATED
  ACCEPTED
  DECLINED
  RESCHEDULED
  CANCELED
  COMPLETED
}

enum EmailOutboxStatus {
  PENDING
  PROCESSING
  RETRY_SCHEDULED
  SENT
  DEAD_LETTER
  SUPPRESSED
}

enum EmailDeliveryAttemptStatus {
  SENT
  RETRYABLE_FAILURE
  PERMANENT_FAILURE
}

enum CompanyInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
  EXPIRED
}

enum CompanyMembershipEventType {
  INVITATION_CREATED
  INVITATION_ACCEPTED
  INVITATION_DECLINED
  INVITATION_REVOKED
  INVITATION_EXPIRED
  MEMBER_PROMOTED_TO_OWNER
  OWNER_DEMOTED_TO_MEMBER
  MEMBER_REMOVED
  OWNER_REMOVED
  MEMBER_LEFT
  OWNER_LEFT
}

model User {
  id                      String                       @id
  name                    String
  email                   String
  emailVerified           Boolean                      @default(false)
  image                   String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  role                    Role                         @default(CANDIDATE)
  sessions                Session[]
  accounts                Account[]
  candidateProfile        CandidateProfile?
  recruiterProfile        RecruiterProfile?
  companyMemberships      CompanyMembership[]
  applications            JobApplication[]             @relation("CandidateApplications")
  savedJobs               SavedJob[]                   @relation("CandidateSavedJobs")
  statusChanges           ApplicationStatusHistory[]   @relation("StatusChangedBy")
  documents               CandidateDocument[]          @relation("CandidateDocuments")
  currentResume           CandidateResume?             @relation("CandidateCurrentResume")
  documentAccessLogs      CandidateDocumentAccessLog[] @relation("DocumentAccessActor")
  applicationNotes        ApplicationNote[]            @relation("ApplicationNoteAuthor")
  noteRevisions           ApplicationNoteRevision[]    @relation("ApplicationNoteRevisionActor")
  notifications           Notification[]               @relation("NotificationRecipient")
  actedNotifications      Notification[]               @relation("NotificationActor")
  receivedInvitations     CompanyInvitation[]          @relation("CompanyInvitationInvitee")
  sentInvitations         CompanyInvitation[]          @relation("CompanyInvitationInviter")
  membershipEventsActed   CompanyMembershipEvent[]     @relation("CompanyMembershipEventActor")
  membershipEventsSubject CompanyMembershipEvent[]     @relation("CompanyMembershipEventSubject")
  emailPreferences        UserEmailPreference[]
  emailOutbox             EmailOutbox[]                @relation("EmailOutboxRecipient")
  organizedInterviews     Interview[]                  @relation("InterviewOrganizer")
  interviewEvents         InterviewEvent[]             @relation("InterviewEventActor")

  @@unique([email])
  @@map("user")
}

model RecruiterProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  jobTitle    String?  @db.VarChar(160)
  bio         String?  @db.VarChar(2000)
  linkedinUrl String?  @db.VarChar(2048)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recruiter_profile")
}

model Company {
  id           String       @id @default(cuid())
  name         String       @db.VarChar(160)
  slug         String       @unique @db.VarChar(180)
  tagline      String?      @db.VarChar(240)
  description  String?      @db.VarChar(4000)
  industry     String?      @db.VarChar(120)
  headquarters String?      @db.VarChar(160)
  websiteUrl   String?      @db.VarChar(2048)
  companySize  CompanySize?
  foundedYear  Int?         @db.SmallInt
  isPublished  Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships      CompanyMembership[]
  jobs             Job[]
  notifications    Notification[]
  invitations      CompanyInvitation[]
  membershipEvents CompanyMembershipEvent[]
  emailOutbox      EmailOutbox[]

  @@index([isPublished, name])
  @@map("company")
}

model CompanyMembership {
  id        String                @id @default(cuid())
  userId    String
  companyId String
  role      CompanyMembershipRole @default(MEMBER)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId, role])
  @@index([userId, role])
  @@map("company_membership")
}

/// Invitation for an EXISTING CareerBridge Recruiter account to join a Company
/// as a MEMBER. There are no public invitation links, tokens, or emails in this
/// phase: the invitee responds from their authenticated in-app invitation list,
/// so authorization is always `inviteeUserId = session user`. Company and User
/// display data (names, emails) are read through the relations, never
/// duplicated here. Rows are retained after resolution as history.
model CompanyInvitation {
  id              String                  @id @default(cuid())
  companyId       String
  inviteeUserId   String
  // Nullable so invitation history survives removal of the inviter account.
  invitedByUserId String?
  status          CompanyInvitationStatus @default(PENDING)
  // Server-generated "companyId:inviteeUserId" while the invitation is
  // PENDING, cleared (null) on every terminal transition. The unique
  // constraint makes "at most one active invitation per Company + invitee"
  // database-backed (PostgreSQL permits many NULLs). Not a secret and never a
  // public link token.
  activeKey       String?                 @unique @db.VarChar(130)
  expiresAt       DateTime
  respondedAt     DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  company     Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitee     User                     @relation("CompanyInvitationInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)
  invitedBy   User?                    @relation("CompanyInvitationInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  events      CompanyMembershipEvent[]
  emailOutbox EmailOutbox[]

  // Invitee incoming list (pending first by status filter) and history.
  @@index([inviteeUserId, status, createdAt])
  // Company pending invitations and invitation history for the team page.
  @@index([companyId, status, createdAt])
  // Expiration sweeps over active invitations.
  @@index([status, expiresAt])
  @@map("company_invitation")
}

/// Immutable, append-only audit record of Company membership and invitation
/// changes. Created in the same transaction as the domain change it describes;
/// never edited or deleted in the normal workflow. Visible only to Company
/// OWNERs. Actor/subject/invitation references are nullable (`SetNull`) so the
/// audit trail survives account or invitation removal. No free-text metadata.
model CompanyMembershipEvent {
  id            String                     @id @default(cuid())
  companyId     String
  // The user who performed the action; null for system transitions (expiry)
  // or after actor account removal.
  actorUserId   String?
  // The user the event is about; null after subject account removal.
  subjectUserId String?
  invitationId  String?
  type          CompanyMembershipEventType
  fromRole      CompanyMembershipRole?
  toRole        CompanyMembershipRole?
  createdAt     DateTime                   @default(now())

  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor      User?              @relation("CompanyMembershipEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  subject    User?              @relation("CompanyMembershipEventSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)
  invitation CompanyInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)

  // Company audit timeline, newest first.
  @@index([companyId, createdAt])
  // Actor-scoped audit lookups.
  @@index([actorUserId, createdAt])
  @@index([invitationId])
  @@map("company_membership_event")
}

model Job {
  id                  String           @id @default(cuid())
  companyId           String
  title               String           @db.VarChar(160)
  slug                String           @unique @db.VarChar(200)
  summary             String?          @db.VarChar(320)
  description         String?          @db.VarChar(8000)
  responsibilities    String?          @db.VarChar(6000)
  requirements        String?          @db.VarChar(6000)
  location            String?          @db.VarChar(160)
  employmentType      EmploymentType?
  workplaceType       WorkplaceType?
  experienceLevel     ExperienceLevel?
  // Salary is stored as whole currency units (e.g. 90000 = 90,000), never minor
  // units, to keep monetary values as exact integers rather than floats.
  salaryMin           Int?
  salaryMax           Int?
  salaryCurrency      String?          @db.Char(3)
  applicationDeadline DateTime?        @db.Date
  status              JobStatus        @default(DRAFT)
  publishedAt         DateTime?
  closedAt            DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skills        JobSkill[]
  applications  JobApplication[]
  savedBy       SavedJob[]
  notifications Notification[]

  @@index([companyId, status, createdAt])
  @@index([status, publishedAt, id])
  @@map("job")
}

model SavedJob {
  id          String   @id @default(cuid())
  candidateId String
  jobId       String
  createdAt   DateTime @default(now())

  candidate User @relation("CandidateSavedJobs", fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
  @@index([candidateId, createdAt, id])
  @@index([jobId])
  @@map("saved_job")
}

model JobSkill {
  jobId     String
  skillId   String
  createdAt DateTime @default(now())

  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
  @@index([skillId])
  @@map("job_skill")
}

model JobApplication {
  id               String            @id @default(cuid())
  jobId            String
  candidateId      String
  coverLetter      String?           @db.VarChar(6000)
  status           ApplicationStatus @default(SUBMITTED)
  // Immutable snapshot of the Candidate's current CV at submission time. Stays
  // pinned to that exact document even after the Candidate replaces their CV.
  // Null preserves backward compatibility with pre-Phase-3C applications.
  resumeDocumentId String?
  submittedAt      DateTime          @default(now())
  withdrawnAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  job                Job                          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate          User                         @relation("CandidateApplications", fields: [candidateId], references: [id], onDelete: Cascade)
  history            ApplicationStatusHistory[]
  resumeDocument     CandidateDocument?           @relation("ApplicationResume", fields: [resumeDocumentId], references: [id], onDelete: SetNull)
  documentAccessLogs CandidateDocumentAccessLog[]
  notes              ApplicationNote[]
  notifications      Notification[]
  emailOutbox        EmailOutbox[]
  interviews         Interview[]

  // One application per Candidate per Job, enforced at the database layer.
  @@unique([jobId, candidateId])
  @@index([candidateId, status, submittedAt])
  @@index([jobId, status, submittedAt])
  @@index([resumeDocumentId])
  @@map("job_application")
}

model ApplicationStatusHistory {
  id              String             @id @default(cuid())
  applicationId   String
  // Null fromStatus marks the initial SUBMITTED event.
  fromStatus      ApplicationStatus?
  toStatus        ApplicationStatus
  changedByUserId String?
  createdAt       DateTime           @default(now())

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  // Preserve history if the acting user is later removed.
  changedBy   User?          @relation("StatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([applicationId, createdAt])
  @@map("application_status_history")
}

/// One scheduled Interview for a JobApplication. An Application may hold many
/// Interviews over its lifetime. `startAt`/`endAt` are UTC instants; the
/// separately stored IANA `timeZone` drives display (including DST), never
/// authorization. `organizerUserId` is always server-derived from the acting
/// Company OWNER session and survives account removal as null. `version`
/// starts at 1 and increments on every state or schedule change (optimistic
/// concurrency token only — never authorization). Interviews are never
/// hard-deleted in the normal workflow; terminal rows remain as history even
/// after the Application itself terminates. Candidate, Job, Company, and
/// Recruiter data are read through authorized relations, never duplicated
/// here. Meeting URL, location, and instructions are private schedule details
/// exposed only on authenticated, re-authorized Interview routes.
model Interview {
  id                   String          @id @default(cuid())
  applicationId        String
  // Null once the organizing user account is removed.
  organizerUserId      String?
  title                String          @db.VarChar(120)
  format               InterviewFormat
  status               InterviewStatus @default(PENDING_RESPONSE)
  startAt              DateTime
  endAt                DateTime
  timeZone             String          @db.VarChar(100)
  location             String?         @db.VarChar(300)
  meetingUrl           String?         @db.VarChar(1000)
  instructions         String?         @db.VarChar(3000)
  version              Int             @default(1)
  candidateRespondedAt DateTime?
  canceledAt           DateTime?
  completedAt          DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  application JobApplication   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  organizer   User?            @relation("InterviewOrganizer", fields: [organizerUserId], references: [id], onDelete: SetNull)
  events      InterviewEvent[]

  // Application interview list, oldest schedule first.
  @@index([applicationId, startAt])
  // Organizer conflict windows and organizer agenda scans.
  @@index([organizerUserId, status, startAt])
  // Status-filtered upcoming/past agenda queries.
  @@index([status, startAt])
  @@index([createdAt])
  @@map("interview")
}

/// Append-only, immutable audit record of one Interview transition. Created in
/// the same transaction as the Interview change it describes; never edited or
/// deleted in the normal workflow and never exposed through an edit/delete
/// surface. `startAt`/`endAt`/`timeZone` snapshot the schedule for CREATED and
/// RESCHEDULED events so the full scheduling history survives later changes.
/// Actor references are nullable (`SetNull`) so history outlives account
/// removal. No emails, CV metadata, note content, or raw HTML are ever stored.
model InterviewEvent {
  id          String             @id @default(cuid())
  interviewId String
  // Null for events whose acting user account was later removed.
  actorUserId String?
  type        InterviewEventType
  // Null fromStatus marks the initial CREATED event.
  fromStatus  InterviewStatus?
  toStatus    InterviewStatus
  // Schedule snapshot, set for CREATED and RESCHEDULED events.
  startAt     DateTime?
  endAt       DateTime?
  timeZone    String?            @db.VarChar(100)
  createdAt   DateTime           @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  actor     User?     @relation("InterviewEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  // Interview history timeline, oldest first.
  @@index([interviewId, createdAt])
  // Actor-scoped audit lookups.
  @@index([actorUserId, createdAt])
  @@map("interview_event")
}

/// Immutable Candidate document version. Each upload creates a new row; the
/// stored object and every metadata field are never overwritten (only
/// removedFromProfileAt is set when the version leaves the active profile).
/// File bytes live in private object storage, never in PostgreSQL.
model CandidateDocument {
  id                   String                @id @default(cuid())
  candidateId          String
  kind                 CandidateDocumentKind @default(RESUME)
  // Opaque, server-generated storage object key. Never exposed to the browser.
  storageKey           String                @unique @db.VarChar(255)
  // Sanitized display filename, safe for Content-Disposition.
  originalFilename     String                @db.VarChar(255)
  mimeType             String                @db.VarChar(120)
  sizeBytes            Int
  sha256               String                @db.Char(64)
  uploadedAt           DateTime              @default(now())
  removedFromProfileAt DateTime?
  createdAt            DateTime              @default(now())

  candidate    User                         @relation("CandidateDocuments", fields: [candidateId], references: [id], onDelete: Cascade)
  currentFor   CandidateResume?
  applications JobApplication[]             @relation("ApplicationResume")
  accessLogs   CandidateDocumentAccessLog[]

  @@index([candidateId, kind, uploadedAt])
  @@index([candidateId, createdAt])
  @@map("candidate_document")
}

/// One-to-one pointer to a Candidate's current CV. candidateId is the primary
/// key (at most one current resume per Candidate); documentId is unique (a
/// document is current for at most one Candidate). Cleared when the Candidate
/// removes their CV so old versions stay attached to historical applications.
model CandidateResume {
  candidateId String   @id
  documentId  String   @unique
  updatedAt   DateTime @updatedAt

  candidate User              @relation("CandidateCurrentResume", fields: [candidateId], references: [id], onDelete: Cascade)
  document  CandidateDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("candidate_resume")
}

/// Minimal, server-controlled audit trail of successful authorized document
/// downloads. Denied attempts are never recorded here.
model CandidateDocumentAccessLog {
  id            String                      @id @default(cuid())
  documentId    String
  actorUserId   String
  // Null for a Candidate downloading their own document outside an application.
  applicationId String?
  accessType    CandidateDocumentAccessType
  createdAt     DateTime                    @default(now())

  document    CandidateDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actor       User              @relation("DocumentAccessActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  application JobApplication?   @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([documentId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("candidate_document_access_log")
}

/// Internal Recruiter-only note on a Job Application. Visible only to OWNER
/// members of the Application's Job Company — never to the Candidate, MEMBER
/// users, other companies, Admins, or any public surface. `body` holds the
/// current active text; `revision` starts at 1 and increases on each edit or
/// soft deletion. A null `deletedAt` marks an active note; notes are never
/// hard-deleted in the normal workflow. Candidate/Recruiter/Job/Company data
/// is read through authorized relations, never duplicated here.
model ApplicationNote {
  id            String    @id @default(cuid())
  applicationId String
  // Nullable so the audit trail survives author account removal.
  authorUserId  String?
  body          String    @db.VarChar(5000)
  revision      Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  application JobApplication            @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author      User?                     @relation("ApplicationNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  revisions   ApplicationNoteRevision[]

  // Active-note lists and counts per Application (newest first), and
  // author-owned note lookups.
  @@index([applicationId, deletedAt, createdAt])
  @@index([authorUserId])
  @@map("application_note")
}

/// Immutable revision-history entry for an ApplicationNote. Created alongside
/// every note create, edit, and soft delete in the same transaction. Records
/// are never edited or removed in the normal workflow.
model ApplicationNoteRevision {
  id          String                        @id @default(cuid())
  noteId      String
  version     Int
  action      ApplicationNoteRevisionAction
  // CREATED/EDITED preserve the full note text at that version; DELETED keeps
  // the final body for authorized audit review.
  body        String                        @db.VarChar(5000)
  // Nullable so history survives actor account removal.
  actorUserId String?
  createdAt   DateTime                      @default(now())

  note  ApplicationNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  actor User?           @relation("ApplicationNoteRevisionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  // One row per (note, version) is the authoritative concurrency guard.
  @@unique([noteId, version])
  @@index([noteId, version])
  @@index([actorUserId, createdAt])
  @@map("application_note_revision")
}

/// In-app notification delivered to exactly one recipient User. Title, message,
/// and href are immutable, server-generated event snapshots — never rendered as
/// HTML/Markdown and never containing Candidate email, CV filenames, note
/// bodies, or other private metadata. Application/Job/Company links are nullable
/// and set null on deletion so delivery history is retained without exposing an
/// inaccessible private record; the destination route always re-authorizes
/// independently. `dedupeKey` is a deterministic server value with a unique
/// constraint that makes transactional retries and concurrent duplicate events
/// idempotent. A null `readAt` marks an unread notification.
model Notification {
  id              String           @id @default(cuid())
  recipientUserId String
  // Null once the acting user is removed, so history survives.
  actorUserId     String?
  type            NotificationType
  title           String           @db.VarChar(160)
  message         String           @db.VarChar(500)
  // Server-generated, safe internal path only.
  href            String           @db.VarChar(512)
  // Retained context links; set null (not cascaded) so the notification row and
  // its snapshot text outlive deletion of the underlying entity.
  applicationId   String?
  jobId           String?
  companyId       String?
  // Deterministic idempotency key; never supplied by the browser.
  dedupeKey       String           @unique @db.VarChar(200)
  readAt          DateTime?
  createdAt       DateTime         @default(now())

  recipient   User            @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actor       User?           @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  application JobApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  job         Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)
  company     Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Recipient unread count + read-state filtering + newest-first ordering.
  @@index([recipientUserId, readAt, createdAt])
  // Recipient newest-first full list.
  @@index([recipientUserId, createdAt])
  // Application-scoped notification lookups.
  @@index([applicationId])
  @@map("notification")
}

/// A User's email-only preference for one supported transactional event.
/// Missing rows mean enabled. These settings never affect in-app Notifications.
model UserEmailPreference {
  id        String         @id @default(cuid())
  userId    String
  eventType EmailEventType
  enabled   Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@index([userId])
  @@map("user_email_preference")
}

/// Private, immutable email-intent snapshot created in the authoritative
/// business transaction. External provider I/O happens only after queue claim.
model EmailOutbox {
  id                String            @id @default(cuid())
  recipientUserId   String?
  recipientEmail    String            @db.VarChar(320)
  eventType         EmailEventType
  subject           String            @db.VarChar(200)
  textBody          String            @db.Text
  htmlBody          String            @db.Text
  destinationPath   String            @db.VarChar(512)
  dedupeKey         String            @unique @db.VarChar(200)
  status            EmailOutboxStatus @default(PENDING)
  attemptCount      Int               @default(0)
  maxAttempts       Int               @default(5)
  nextAttemptAt     DateTime          @default(now())
  lockedAt          DateTime?
  lockToken         String?           @db.VarChar(64)
  sentAt            DateTime?
  lastErrorCode     String?           @db.VarChar(120)
  providerMessageId String?           @db.VarChar(255)
  applicationId     String?
  companyId         String?
  invitationId      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  recipient   User?                  @relation("EmailOutboxRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  application JobApplication?        @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  company     Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  invitation  CompanyInvitation?     @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  attempts    EmailDeliveryAttempt[]

  @@index([status, nextAttemptAt, createdAt])
  @@index([status, lockedAt])
  @@index([recipientUserId, createdAt])
  @@index([applicationId])
  @@index([companyId])
  @@index([invitationId])
  @@map("email_outbox")
}

/// Append-only, privacy-bounded audit record for one provider attempt.
model EmailDeliveryAttempt {
  id                String                     @id @default(cuid())
  outboxId          String
  attemptNumber     Int
  status            EmailDeliveryAttemptStatus
  provider          String                     @db.VarChar(40)
  providerMessageId String?                    @db.VarChar(255)
  errorCode         String?                    @db.VarChar(120)
  startedAt         DateTime
  finishedAt        DateTime
  createdAt         DateTime                   @default(now())

  outbox EmailOutbox @relation(fields: [outboxId], references: [id], onDelete: Cascade)

  @@unique([outboxId, attemptNumber])
  @@index([outboxId, createdAt])
  @@map("email_delivery_attempt")
}

model CandidateProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  headline    String?  @db.VarChar(160)
  location    String?  @db.VarChar(120)
  bio         String?  @db.VarChar(2000)
  websiteUrl  String?  @db.VarChar(2048)
  linkedinUrl String?  @db.VarChar(2048)
  githubUrl   String?  @db.VarChar(2048)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  education  Education[]
  experience Experience[]
  skills     CandidateSkill[]

  @@map("candidate_profile")
}

model Education {
  id                 String   @id @default(cuid())
  candidateProfileId String
  school             String   @db.VarChar(160)
  degree             String?  @db.VarChar(120)
  fieldOfStudy       String?  @db.VarChar(120)
  startYear          Int      @db.SmallInt
  endYear            Int?     @db.SmallInt
  isCurrent          Boolean  @default(false)
  description        String?  @db.VarChar(2000)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("education")
}

model Experience {
  id                 String         @id @default(cuid())
  candidateProfileId String
  companyName        String         @db.VarChar(160)
  jobTitle           String         @db.VarChar(160)
  employmentType     EmploymentType
  location           String?        @db.VarChar(120)
  startDate          DateTime       @db.Date
  endDate            DateTime?      @db.Date
  isCurrent          Boolean        @default(false)
  description        String?        @db.VarChar(2000)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("experience")
}

model Skill {
  id             String   @id @default(cuid())
  name           String   @db.VarChar(80)
  normalizedName String   @unique @db.VarChar(80)
  createdAt      DateTime @default(now())

  candidates CandidateSkill[]
  jobs       JobSkill[]

  @@map("skill")
}

model CandidateSkill {
  candidateProfileId String
  skillId            String
  createdAt          DateTime @default(now())

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  skill            Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([candidateProfileId, skillId])
  @@index([skillId])
  @@map("candidate_skill")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
